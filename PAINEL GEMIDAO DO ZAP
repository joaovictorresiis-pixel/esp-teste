-- Variáveis para o sistema de arrastar
local dragging = false
local dragStart = nil
local startPos = nil

-- Função para tornar a GUI arrastável
local function makeDraggable(frame, dragArea)
    dragArea = dragArea or frame
    
    dragArea.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

makeDraggable(mainFrame, title)

-- Sistema de equipes
local teams = {
    MONSTER = "Monster",
    PLAYER = "Player"
}

local playerTeam = {}
local activeHighlights = {}

-- Função para distribuir equipes aleatoriamente
local function assignTeams()
    local allPlayers = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(allPlayers, player)
        end
    end
    
    for i = #allPlayers, 2, -1 do
        local j = math.random(i)
        allPlayers[i], allPlayers[j] = allPlayers[j], allPlayers[i]
    end
    
    local monsterCount = math.max(1, math.floor(#allPlayers * 0.2))
    
    for i, player in ipairs(allPlayers) do
        if i <= monsterCount then
            playerTeam[player] = teams.MONSTER
        else
            playerTeam[player] = teams.PLAYER
        end
    end
end

-- Função para criar highlight
local function createHighlight(character, color)
    if not character then return nil end
    
    local highlight = Instance.new("Highlight")
    highlight.FillColor = color
    highlight.OutlineColor = color
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0.3
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = character
    
    return highlight
end

-- Função para criar texto flutuante (corrigida para ficar no tronco)
local function createBillboard(character, text, color)
    if not character then return nil end
    
    -- Procura o torso ou humanoidrootpart para anexar o billboard
    local attachPoint = character:FindFirstChild("UpperTorso") or 
                        character:FindFirstChild("Torso") or 
                        character:FindFirstChild("HumanoidRootPart")
    
    if not attachPoint then return nil end
    
    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 140, 0, 40)
    billboard.StudsOffset = Vector3.new(0, 0.5, 0) -- Centralizado no tronco
    billboard.AlwaysOnTop = true
    billboard.Parent = attachPoint
    
    -- Fundo semi-transparente para melhor visibilidade
    local background = Instance.new("Frame")
    background.Size = UDim2.new(1, 0, 1, 0)
    background.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    background.BackgroundTransparency = 0.3
    background.BorderSizePixel = 0
    background.Parent = billboard
    
    local bgCorner = Instance.new("UICorner")
    bgCorner.CornerRadius = UDim.new(0, 8)
    bgCorner.Parent = background
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = text
    textLabel.TextColor3 = color
    textLabel.TextSize = 16
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextStrokeTransparency = 0.2
    textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    textLabel.Parent = billboard
    
    return billboard
end

-- Função para remover highlight
local function removeHighlight(player)
    if activeHighlights[player] then
        if activeHighlights[player].highlight then
            activeHighlights[player].highlight:Destroy()
        end
        if activeHighlights[player].billboard then
            activeHighlights[player].billboard:Destroy()
        end
        activeHighlights[player] = nil
    end
end

-- Função para atualizar todos os highlights
local function updateAllHighlights()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local character = player.Character
            if character and (character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")) then
                local team = playerTeam[player]
                
                if team == teams.MONSTER then
                    if not activeHighlights[player] or activeHighlights[player].type ~= "monster" then
                        removeHighlight(player)
                        local highlight = createHighlight(character, Color3.fromRGB(255, 50, 50))
                        local billboard = createBillboard(character, "MONSTER", Color3.fromRGB(255, 80, 80))
                        activeHighlights[player] = {
                            type = "monster",
                            highlight = highlight,
                            billboard = billboard
                        }
                    end
                elseif team == teams.PLAYER then
                    if not activeHighlights[player] or activeHighlights[player].type ~= "player" then
                        removeHighlight(player)
                        local highlight = createHighlight(character, Color3.fromRGB(0, 120, 255))
                        local billboard = createBillboard(character, "PLAYER", Color3.fromRGB(0, 150, 255))
                        activeHighlights[player] = {
                            type = "player",
                            highlight = highlight,
                            billboard = billboard
                        }
                    end
                end
            else
                removeHighlight(player)
            end
        end
    end
end

-- Função para limpar todos os highlights
local function clearAllHighlights()
    for player, _ in pairs(activeHighlights) do
        removeHighlight(player)
    end
    activeHighlights = {}
end

-- Função para criar botão estilizado
local function createButton(name, text, yPos, color, activeColor)
    local button = Instance.new("TextButton")
    button.Name = name
    button.Size = UDim2.new(0.8, 0, 0, 45)
    button.Position = UDim2.new(0.1, 0, 0, yPos)
    button.BackgroundColor3 = color
    button.Text = text
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.TextSize = 15
    button.Font = Enum.Font.GothamSemibold
    button.BorderSizePixel = 0
    button.Parent = mainFrame
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 8)
    btnCorner.Parent = button
    
    button.MouseEnter:Connect(function()
        button.BackgroundColor3 = Color3.fromRGB(color.R + 20, color.G + 20, color.B + 20)
    end)
    
    button.MouseLeave:Connect(function()
        button.BackgroundColor3 = color
    end)
    
    return button
end

