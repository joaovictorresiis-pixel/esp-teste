local espButton = createButton("ESPButton", "ATIVAR ESP", 80, Color3.fromRGB(0, 80, 160), Color3.fromRGB(0, 120, 255))
local randomizeButton = createButton("RandomizeButton", "RANDOMIZAR EQUIPES", 145, Color3.fromRGB(80, 80, 160), Color3.fromRGB(100, 100, 200))

-- Variável de controle do ESP
local espActive = false

-- Evento do botão ESP
espButton.MouseButton1Click:Connect(function()
    espActive = not espActive
    
    if espActive then
        espButton.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
        espButton.Text = "DESATIVAR ESP"
        
        if next(playerTeam) == nil then
            assignTeams()
        end
        
        updateAllHighlights()
    else
        espButton.BackgroundColor3 = Color3.fromRGB(0, 80, 160)
        espButton.Text = "ATIVAR ESP"
        clearAllHighlights()
    end
end)

-- Evento do botão Randomizar Equipes
randomizeButton.MouseButton1Click:Connect(function()
    assignTeams()
    
    if espActive then
        updateAllHighlights()
    end
    
    randomizeButton.BackgroundColor3 = Color3.fromRGB(100, 100, 200)
    wait(0.2)
    randomizeButton.BackgroundColor3 = Color3.fromRGB(80, 80, 160)
end)

-- Eventos de players
local function onCharacterAdded(player, character)
    wait(0.5)
    if espActive then
        updateAllHighlights()
    end
end

local function onPlayerAdded(player)
    if player ~= LocalPlayer then
        if next(playerTeam) == nil then
            assignTeams()
        else
            playerTeam[player] = teams.PLAYER
        end
        
        if player.Character then
            onCharacterAdded(player, player.Character)
        end
        player.CharacterAdded:Connect(function(character)
            onCharacterAdded(player, character)
        end)
    end
end

local function onPlayerRemoving(player)
    removeHighlight(player)
    playerTeam[player] = nil
end

-- Conectar eventos
for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        onPlayerAdded(player)
    end
end

Players.PlayerAdded:Connect(onPlayerAdded)
Players.PlayerRemoving:Connect(onPlayerRemoving)

-- Loop de atualização
RunService.Heartbeat:Connect(function()
    if espActive then
        updateAllHighlights()
    end
end)

