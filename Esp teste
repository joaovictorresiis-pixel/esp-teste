-- Função para criar ESP para um jogador
local function createESPForPlayer(player)
    if player == LocalPlayer then return end
    
    -- Criar Highlight
    local highlight = Instance.new("Highlight")
    highlight.Name = "JoaoESP_Highlight"
    highlight.Adornee = player.Character or player.CharacterAdded:Wait()
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.FillColor = Color3.fromRGB(0, 100, 255) -- Azul padrão
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.OutlineTransparency = 0.7
    highlight.Parent = player.Character
    
    -- Criar BillboardGui com texto
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "JoaoESP_Text"
    billboard.Adornee = player.Character:FindFirstChild("Head") or player.Character:WaitForChild("Head")
    billboard.Size = UDim2.new(0, 100, 0, 40)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = "PLAYER"
    textLabel.TextColor3 = Color3.fromRGB(0, 150, 255)
    textLabel.TextSize = 18
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextStrokeTransparency = 0.3
    textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    textLabel.Parent = billboard
    
    billboard.Parent = player.Character
    
    -- Armazenar objetos para referência futura
    if not espObjects[player] then
        espObjects[player] = {}
    end
    espObjects[player].highlight = highlight
    espObjects[player].billboard = billboard
    
    -- Verificar se é o monstro (exemplo: baseado no nome)
    -- Você pode ajustar esta lógica conforme necessário
    if player.Name:lower():find("monstro") or player.DisplayName:lower():find("monstro") then
        highlight.FillColor = Color3.fromRGB(255, 0, 0)
        textLabel.Text = "MONSTRO"
        textLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
    end
    
    -- Atualizar quando o personagem mudar
    player.CharacterAdded:Connect(function(character)
        wait(1) -- Aguardar o personagem carregar
        if espEnabled and espObjects[player] then
            highlight.Adornee = character
            billboard.Adornee = character:FindFirstChild("Head") or character:WaitForChild("Head")
        end
    end)
end

-- Função para remover ESP de um jogador
local function removeESPForPlayer(player)
    if espObjects[player] then
        if espObjects[player].highlight then
            espObjects[player].highlight:Destroy()
        end
        if espObjects[player].billboard then
            espObjects[player].billboard:Destroy()
        end
        espObjects[player] = nil
    end
end

-- Função para ativar/desativar ESP para todos os jogadores
local function toggleESP(state)
    espEnabled = state
    
    -- Atualizar interface
    toggleButton.Text = state and "ON" or "OFF"
    toggleButton.BackgroundColor3 = state and Color3.fromRGB(50, 200, 100) or Color3.fromRGB(200, 60, 60)
    statusIndicator.BackgroundColor3 = state and Color3.fromRGB(50, 200, 100) or Color3.fromRGB(200, 60, 60)
    
    -- Animar o frame principal
    TweenService:Create(mainFrame, TweenInfo.new(0.3), {
        BackgroundColor3 = state and Color3.fromRGB(30, 30, 45) or Color3.fromRGB(25, 25, 35)
    }):Play()
    
    if state then
        -- Criar ESP para todos os jogadores existentes
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                createESPForPlayer(player)
            end
        end
    else
        -- Remover ESP de todos os jogadores
        for player, _ in pairs(espObjects) do
            removeESPForPlayer(player)
        end
    end
end

-- Conectar o botão toggle
