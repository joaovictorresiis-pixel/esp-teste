-- Variáveis de estado
local states = {
    esp = false,
    monster = false
}

local activeESP = {} -- Armazena highlights dos players
local currentMonster = nil

-- Função para criar botão estilizado
local function createButton(name, text, yPos, color, activeColor)
    local button = Instance.new("TextButton")
    button.Name = name
    button.Size = UDim2.new(0.8, 0, 0, 45)
    button.Position = UDim2.new(0.1, 0, 0, yPos)
    button.BackgroundColor3 = color
    button.Text = text
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.TextSize = 15
    button.Font = Enum.Font.GothamSemibold
    button.BorderSizePixel = 0
    button.Parent = mainFrame
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 8)
    btnCorner.Parent = button
    
    local btnStroke = Instance.new("UIStroke")
    btnStroke.Thickness = 0
    btnStroke.Parent = button
    
    -- Efeito hover
    button.MouseEnter:Connect(function()
        button.BackgroundColor3 = Color3.fromRGB(color.R + 20, color.G + 20, color.B + 20)
    end)
    
    button.MouseLeave:Connect(function()
        local currentColor = states[name:lower():gsub("button", "")] == true and activeColor or color
        button.BackgroundColor3 = currentColor
    end)
    
    return button
end

-- Função para criar highlight
local function addHighlight(character, color)
    if not character then return nil end
    
    local highlight = Instance.new("Highlight")
    highlight.FillColor = color
    highlight.OutlineColor = color
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0.3
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = character
    
    return highlight
end

-- Função para criar texto flutuante
local function addNameTag(character, text, color)
    if not character then return nil end
    
    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 120, 0, 30)
    billboard.StudsOffset = Vector3.new(0, 2.5, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = character
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = text
    textLabel.TextColor3 = color
    textLabel.TextSize = 14
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextStrokeTransparency = 0.2
    textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    textLabel.Parent = billboard
    
    return billboard
end

-- Função para limpar ESP de um player
local function clearESP(player)
    if activeESP[player] then
        if activeESP[player].highlight then
            activeESP[player].highlight:Destroy()
        end
        if activeESP[player].nametag then
            activeESP[player].nametag:Destroy()
        end
        activeESP[player] = nil
    end
end

-- Função para atualizar ESP de todos os players
local function updateESP()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local character = player.Character
            if character and character:FindFirstChild("HumanoidRootPart") then
                
                if states.esp then
                    if not activeESP[player] then
                        local highlight = addHighlight(character, Color3.fromRGB(0, 120, 255))
                        local nametag = addNameTag(character, "PLAYER", Color3.fromRGB(0, 150, 255))
                        activeESP[player] = {
                            highlight = highlight,
                            nametag = nametag
                        }
                    end
                else
                    clearESP(player)
                end
                
            end
        end
    end
end

-- Função para atualizar modo monster
local function updateMonster()
    if states.monster then
        -- Pega o primeiro player não-local como monster
        local monsterPlayer = nil
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                monsterPlayer = player
                break
            end
        end
        
        if monsterPlayer and monsterPlayer.Character then
            if currentMonster ~= monsterPlayer then
                -- Limpa monster anterior
                if currentMonster and currentMonster.highlight then
                    currentMonster.highlight:Destroy()
                end
                if currentMonster and currentMonster.nametag then
                    currentMonster.nametag:Destroy()
                end
                
                -- Cria novo monster
                local highlight = addHighlight(monsterPlayer.Character, Color3.fromRGB(255, 50, 50))
                local nametag = addNameTag(monsterPlayer.Character, "MONSTER", Color3.fromRGB(255, 80, 80))
                currentMonster = {
                    player = monsterPlayer,
                    highlight = highlight,
                    nametag = nametag
                }
            end
        end
    else
        -- Remove monster
        if currentMonster then
            if currentMonster.highlight then
                currentMonster.highlight:Destroy()
            end
            if currentMonster.nametag then
                currentMonster.nametag:Destroy()
            end
            currentMonster = nil
        end
    end
end

-- Criar botões
local espBtn = createButton("ESPButton", "ESP PLAYERS", 80, Color3.fromRGB(0, 80, 160), Color3.fromRGB(0, 120, 255))
local monsterBtn = createButton("MonsterButton", "MONSTER MODE", 145, Color3.fromRGB(160, 40, 40), Color3.fromRGB(255, 60, 60))

-- Eventos dos botões
espBtn.MouseButton1Click:Connect(function()
    states.esp = not states.esp
    
    if states.esp then
        espBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
        updateESP()
    else
        espBtn.BackgroundColor3 = Color3.fromRGB(0, 80, 160)
        -- Limpa todos os ESPs
        for player, _ in pairs(activeESP) do
            clearESP(player)
        end
        activeESP = {}
    end
end)

monsterBtn.MouseButton1Click:Connect(function()
    states.monster = not states.monster
    
    if states.monster then
        monsterBtn.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
        updateMonster()
    else
        monsterBtn.BackgroundColor3 = Color3.fromRGB(160, 40, 40)
        if currentMonster then
            if currentMonster.highlight then
                currentMonster.highlight:Destroy()
            end
            if currentMonster.nametag then
                currentMonster.nametag:Destroy()
            end
            currentMonster = nil
        end
    end
end)

-- Eventos de players
local function onCharacterAdded(player, character)
    wait(0.5)
    if states.esp then
        updateESP()
    end
    if states.monster then
        updateMonster()
    end
end

local function onPlayerAdded(player)
    if player.Character then
        onCharacterAdded(player, player.Character)
    end
    player.CharacterAdded:Connect(function(character)
        onCharacterAdded(player, character)
    end)
end

local function onPlayerRemoving(player)
    clearESP(player)
    if currentMonster and currentMonster.player == player then
        if currentMonster.highlight then
            currentMonster.highlight:Destroy()
        end
        if currentMonster.nametag then
            currentMonster.nametag:Destroy()
        end
        currentMonster = nil
    end
end

-- Conectar eventos
for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        onPlayerAdded(player)
    end
end

Players.PlayerAdded:Connect(onPlayerAdded)
Players.PlayerRemoving:Connect(onPlayerRemoving)

-- Loop de atualização
RunService.Heartbeat:Connect(function()
    if states.esp then
        updateESP()
    end
    if states.monster then
        updateMonster()
    end
end)

